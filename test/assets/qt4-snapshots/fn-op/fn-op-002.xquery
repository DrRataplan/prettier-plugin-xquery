every
  $s in
  (
    ",",
    "and",
    "or",
    "+",
    "-",
    "*",
    "div",
    "idiv",
    "mod",
    "=",
    "<",
    "<=",
    ">",
    ">=",
    "!=",
    "eq",
    "lt",
    "le",
    "gt",
    "ge",
    "ne",
    "<<",
    ">>",
    "is",
    "is-not",
    "precedes",
    "follows",
    "||",
    "|",
    "union",
    "except",
    "intersect",
    "to",
    "otherwise"
  ) satisfies
  function-arity(op($s)) = 2
